{
  "name": "sokak-vitrini-dene",
  "version": "2.0.0",
  "private": true,
  "description": "Sokak Vitrini - ten rengi, kimlik ve vücut oranı koruma odaklı dijital ürün deneme platformu.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "vercel-build": "npm run db:migrate && next build"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
