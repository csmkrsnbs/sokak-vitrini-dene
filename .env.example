# Neon panelindeki pooled PostgreSQL bağlantısı
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# FASHN API - https://app.fashn.ai/api
FASHN_API_KEY="fa_..."

# Model adları gerektiğinde panelden değiştirilebilir
FASHN_CLOTHING_MODEL="tryon-v1.6"
FASHN_WEARABLE_MODEL="tryon-max"
FASHN_STUDIO_MODEL="product-to-model"

# Performans / kalite seçenekleri
FASHN_CLOTHING_MODE="balanced"
FASHN_MAX_MODE="fast"
FASHN_STUDIO_MODE="fast"
FASHN_RESOLUTION="1k"
FASHN_OUTPUT_FORMAT="jpeg"

# Uygulama
NEXT_PUBLIC_APP_URL="https://sokak-vitrini-dene-my7vp86oe-sokak-vitrini.vercel.app"
IMAGE_RETENTION_DAYS="30"
PREVIEW_JOB_MAX_AGE_MS="900000"

# İstanbul saatine göre günlük toplam üretim üst sınırı
DAILY_GENERATION_LIMIT="20"

# Her biri en az 32 karakterlik farklı ve rastgele değer olmalı
RATE_LIMIT_SALT="change-this-to-a-long-random-value"
CRON_SECRET="change-this-to-another-long-random-value"
ADMIN_ACCESS_KEY="change-this-to-a-private-admin-access-key"
COUPON_SIGNING_SECRET="change-this-to-a-separate-coupon-secret"
