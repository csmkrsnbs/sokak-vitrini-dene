# Neon panelindeki pooled bağlantı adresi
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# Sunucu tarafında kullanılan OpenAI anahtarı
OPENAI_API_KEY="sk-proj-..."
OPENAI_IMAGE_MODEL="gpt-image-2"
OPENAI_IMAGE_QUALITY="medium"

# Uygulama ayarları
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AI_PREVIEW_DAILY_LIMIT="10"
IMAGE_RETENTION_DAYS="30"

# En az 32 karakterlik rastgele değerler
RATE_LIMIT_SALT="change-this-to-a-long-random-value"
CRON_SECRET="change-this-to-another-long-random-value"
