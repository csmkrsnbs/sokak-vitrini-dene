# Neon panelindeki pooled bağlantı adresi
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require"

# RunPod Serverless üzerinde çalışan açık kaynaklı FLUX.2 worker
RUNPOD_API_KEY="rpa_..."
RUNPOD_ENDPOINT_ID="endpoint-id"
# GPU çalışmaya başladıktan sonraki üst sınır
RUNPOD_TIMEOUT_MS="240000"
# Kuyruk dahil RunPod iş ömrü ve uygulamadaki sonlandırma sınırı
RUNPOD_JOB_TTL_MS="900000"
PREVIEW_JOB_MAX_AGE_MS="1200000"
FLUX_IMAGE_MODEL="black-forest-labs/FLUX.2-klein-4B"

# Uygulama ayarları
NEXT_PUBLIC_APP_URL="http://localhost:3000"
IMAGE_RETENTION_DAYS="30"

# Ücretsiz denemelerde VPN, proxy ve Tor kontrolü (IPQualityScore)
IPQS_API_KEY="ipqs-private-key"
IP_RISK_CACHE_HOURS="24"

# IBAN ile Standart Paket: 10 görsel / 49 TL
PAYMENT_BANK_NAME="Banka adı"
PAYMENT_ACCOUNT_HOLDER="Hesap sahibi"
PAYMENT_IBAN="TR000000000000000000000000"

# En az 32 karakterlik rastgele değerler
RATE_LIMIT_SALT="change-this-to-a-long-random-value"
CRON_SECRET="change-this-to-another-long-random-value"
ADMIN_ACCESS_KEY="change-this-to-a-private-admin-access-key"
COUPON_SIGNING_SECRET="change-this-to-a-separate-coupon-secret"
